{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/unos",
      "destination": "/UNOS",
      "permanent": true
    },
    {
      "source": "/unos/:path*",
      "destination": "/UNOS/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/UNOS/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        },
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "outputDirectory": "public"
}
